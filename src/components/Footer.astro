---
import SocialLinks from './SocialLinks.astro';

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <p class="footer-copy">
        &copy; {currentYear} Manpreet
      </p>
      <SocialLinks size="sm" />
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-xl) 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
      gap: var(--space-md);
    }
  }
</style>
