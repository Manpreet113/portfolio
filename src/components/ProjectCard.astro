---
interface Project {
  name: string;
  tagline: string;
  description: string;
  tech: string[];
  github: string;
  live: string | null;
  image: string;
  featured?: boolean;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="project-card card">
  <div class="image-wrapper">
    <img src={project.image} alt={`Visual representation of ${project.name}`} loading="lazy" />
  </div>

  <div class="card-content">
    <div class="title-row">
      <h3>{project.name}</h3>
      <div class="links">
        <a href={project.github} target="_blank" rel="noopener noreferrer" aria-label={`View ${project.name} on GitHub`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="link-icon">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
          </svg>
        </a>
        {project.live && (
          <a href={project.live} target="_blank" rel="noopener noreferrer" aria-label={`Visit ${project.name} live demo`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="link-icon">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15 3 21 3 21 9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
          </a>
        )}
      </div>
    </div>

    <span class="tagline font-mono text-accent">{project.tagline}</span>
    
    <p class="description">{project.description}</p>

    <div class="tech-stack">
      {project.tech.map((t) => (
        <span class="tag">{t}</span>
      ))}
    </div>
  </div>
</article>

<style>
  .project-card {
    padding: 0 !important; /* Bleeds image to the edges */
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .project-card:hover .image-wrapper img {
    transform: scale(1.04);
  }

  .card-content {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xs);
  }

  .title-row h3 {
    margin: 0;
    font-size: 1.35rem;
  }

  .links {
    display: flex;
    gap: var(--space-md);
  }

  .links a {
    color: var(--color-text-tertiary);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .links a:hover {
    color: var(--color-accent);
  }

  .tagline {
    font-size: 0.85rem;
    margin-bottom: var(--space-md);
    display: block;
    line-height: 1.4;
  }

  .description {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-xl);
    flex-grow: 1;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: auto;
  }

  @media (max-width: 640px) {
    .card-content {
      padding: var(--space-lg);
    }
  }
</style>
