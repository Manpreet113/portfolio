---
---

<section class="hero">
  <div class="hero-content">
    <span class="eyebrow font-mono">hey, I'm</span>

    <h1 class="hero-name">
      <span class="name-line">
        <span class="name-text">Manpreet</span>
        <span class="name-text dot">.</span>
      </span>
    </h1>

    <p class="hero-tagline">
      {[
        "I", "build", "things", "that", "work", "—", "and",
        "sometimes", "break", "things", "that", "don't."
      ].map((word, i) => (
        <span class="word" style={`--word-index: ${i}`}>{word}</span>
      ))}
    </p>

    <p class="hero-bio text-muted">
      Curious builder. Rust enthusiast. Arch Linux daily-driver.
      Currently falling down another rabbit hole.
    </p>

    <div class="hero-cta">
      <a href="/projects" class="btn btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7" />
          <rect x="14" y="3" width="7" height="7" />
          <rect x="3" y="14" width="7" height="7" />
          <rect x="14" y="14" width="7" height="7" />
        </svg>
        See my work
      </a>
      <a href="/contact" class="btn btn-secondary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
          <polyline points="22,6 12,13 2,6" />
        </svg>
        Get in touch
      </a>
    </div>
  </div>

  <div class="scroll-indicator" aria-hidden="true">
    <span class="scroll-text font-mono">scroll</span>
    <svg class="scroll-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl) var(--space-xl);
    padding-top: calc(var(--nav-height) + var(--space-2xl));
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    max-width: 820px;
    width: 100%;
  }

  /* --- Eyebrow --- */
  .eyebrow {
    display: inline-block;
    font-size: 1rem;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    margin-bottom: var(--space-md);
    opacity: 0;
    animation: fadeSlideUp 0.6s var(--ease-out) 0.2s forwards;
  }

  /* --- Name: clip-path reveal --- */
  .hero-name {
    margin-bottom: var(--space-lg);
    line-height: 1.05;
  }

  .name-line {
    display: block;
    overflow: hidden;
  }

  .name-text {
    display: inline-block;
    animation: nameReveal 0.9s var(--ease-out) 0.45s forwards;
    transform: translateY(110%);
  }

  .name-text.dot {
    color: var(--color-accent);
    animation-delay: 0.65s;
  }

  /* --- Tagline: staggered word reveal --- */
  .hero-tagline {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
    max-width: 58ch;
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.35em;
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(18px);
    animation: fadeSlideUp 0.5s var(--ease-out) forwards;
    animation-delay: calc(0.85s + var(--word-index) * 0.045s);
  }

  /* --- Bio --- */
  .hero-bio {
    font-size: 1rem;
    line-height: 1.75;
    max-width: 52ch;
    margin-bottom: var(--space-2xl);
    opacity: 0;
    animation: fadeSlideUp 0.6s var(--ease-out) 1.5s forwards;
  }

  /* --- CTAs --- */
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    opacity: 0;
    animation: fadeSlideUp 0.6s var(--ease-out) 1.7s forwards;
  }

  .hero-cta .btn svg {
    flex-shrink: 0;
  }

  /* --- Scroll Indicator --- */
  .scroll-indicator {
    position: absolute;
    bottom: var(--space-2xl);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    opacity: 0;
    animation: fadeIn 0.8s var(--ease-out) 2.2s forwards;
  }

  .scroll-text {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .scroll-arrow {
    color: var(--color-text-muted);
    animation: bounceDown 1.8s var(--ease-in-out) infinite;
  }

  /* ============================================
     KEYFRAMES
     ============================================ */

  @keyframes nameReveal {
    from {
      transform: translateY(110%);
    }
    to {
      transform: translateY(0);
    }
  }

  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes bounceDown {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(6px); }
  }

  /* ============================================
     RESPONSIVE
     ============================================ */

  @media (max-width: 640px) {
    .hero {
      padding-top: calc(var(--nav-height) + var(--space-xl));
      justify-content: flex-start;
      padding-bottom: var(--space-4xl);
    }

    .hero-content {
      margin-top: var(--space-3xl);
    }

    .hero-cta {
      flex-direction: column;
    }

    .hero-cta .btn {
      justify-content: center;
    }

    .scroll-indicator {
      bottom: var(--space-lg);
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .eyebrow,
    .name-text,
    .word,
    .hero-bio,
    .hero-cta,
    .scroll-indicator {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .scroll-arrow {
      animation: none;
    }
  }
</style>
